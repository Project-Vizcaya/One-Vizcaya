rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'citizen');
    }

    function isAdmin() {
      return isAuth() && (
        request.auth.token.role in ['admin', 'municipal_admin', 'provincial_admin', 'super_admin'] ||
        getUserRole() in ['admin', 'municipal_admin', 'provincial_admin', 'super_admin']
      );
    }

    function isProvincialAdmin() {
      return isAuth() && (
        request.auth.token.role in ['admin', 'provincial_admin', 'super_admin'] ||
        getUserRole() in ['admin', 'provincial_admin', 'super_admin']
      );
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isProvincialAdmin();

      // Per-user report sub-collection
      match /reports/{reportId} {
        allow read, write: if isOwner(userId);
        allow read, update: if isAdmin();
        allow delete: if isProvincialAdmin();
      }
    }

    // Allows collectionGroup('reports') queries for admin dashboard
    match /{path=**}/reports/{reportId} {
      allow read, update: if isAdmin();
      allow delete: if isProvincialAdmin();
    }

    // Announcements — any authenticated citizen can read
    match /announcements/{announcementId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Config (admin UID lists, app config)
    match /config/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Rate limit counters
    match /rate_limits/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Demo / seed data helpers
    match /demo_meta/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
