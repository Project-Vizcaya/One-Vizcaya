rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Auth helpers ───────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    // Check custom token claim first (fast), fall back to Firestore doc (safe)
    function role() {
      return isAuth()
        ? request.auth.token.get('role',
            get(/databases/$(database)/documents/users/$(request.auth.uid))
              .data.get('role', 'citizen'))
        : 'citizen';
    }

    // ─── Role hierarchy ─────────────────────────────────────────────────────
    //   super_admin        → unrestricted access to everything
    //   provincial_admin   → read/write/delete across all municipalities
    //   admin              → legacy role, same power as provincial_admin
    //   municipal_admin    → read/update reports; manage announcements & responders
    //   citizen            → own data only

    function isSuperAdmin() {
      return isAuth() && role() == 'super_admin';
    }

    function isProvincialAdmin() {
      return isAuth() && role() in ['provincial_admin', 'admin', 'super_admin'];
    }

    function isMunicipalAdmin() {
      return isAuth() && role() in ['municipal_admin', 'provincial_admin', 'admin', 'super_admin'];
    }

    // Any admin level (used for broad read access)
    function isAdmin() {
      return isAuth() && role() in ['municipal_admin', 'provincial_admin', 'admin', 'super_admin'];
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ─── Super admin bypass ─────────────────────────────────────────────────
    // super_admin has unrestricted read/write access to every document
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // ─── User profiles ──────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      // A user may create/update their OWN profile but must NOT set or change
      // their own 'role' (privilege-escalation guard). Only provincial+ admins
      // may assign roles. role() falls back to this field, so it must be
      // write-protected against the owner.
      allow create: if (isOwner(userId)
                        && request.resource.data.get('role', 'citizen') == 'citizen')
                    || isProvincialAdmin();
      allow update: if (isOwner(userId)
                        && request.resource.data.get('role', 'citizen')
                           == resource.data.get('role', 'citizen'))
                    || isProvincialAdmin();
      // A user may erase their OWN profile (RA 10173 right to erasure). Their
      // reports are NOT deletable here (see reports rule) — they are archived
      // and retained as official LGU records on account deletion.
      allow delete: if isOwner(userId) || isProvincialAdmin();

      // Per-user reports sub-collection.
      // Anonymous reporting is NOT allowed: every report must carry the
      // verified submitter identity (userId == the owning uid + a phone number).
      // Enforced here at the data layer, not just in the UI.
      match /reports/{reportId} {
        allow read:   if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId)
                      && request.resource.data.userId == userId
                      && request.resource.data.userPhone is string
                      && request.resource.data.userPhone.size() > 0
                      && request.resource.data.isAnonymous == false;
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isProvincialAdmin();
      }

      // Per-user notifications
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
        allow read:        if isAdmin();
        allow write:       if isAdmin(); // Cloud Functions write here
      }

      // Per-user feedback on resolved reports
      match /feedback/{feedbackId} {
        allow read, write: if isOwner(userId);
        allow read:        if isAdmin();
      }

      // Per-user data-subject requests (RA 10173: access/correction/erasure/etc.)
      // Citizens file and read their own; admins (the DPO) read and update status.
      match /dataRequests/{requestId} {
        allow read, create: if isOwner(userId);
        allow read, update: if isAdmin();
        allow delete:       if isProvincialAdmin();
      }
    }

    // ─── Data-subject requests (collectionGroup) ─────────────────────────────
    // Lets the DPO / admins list every privacy request across all users.
    match /{path=**}/dataRequests/{requestId} {
      allow read, update: if isAdmin();
    }

    // ─── Citizen feedback (collectionGroup) ──────────────────────────────────
    // Lets admins read satisfaction ratings across all reports for analytics.
    match /{path=**}/feedback/{feedbackId} {
      allow read: if isAdmin();
    }

    // ─── CollectionGroup query ───────────────────────────────────────────────
    // Citizens need read access ONLY for the community "Recently Resolved" feed,
    // which queries where status == 'solved'. Restricting the rule to solved
    // reports forces that filter and stops citizens from reading other people's
    // open reports (descriptions, phone, GPS) via a collectionGroup query.
    // Owners still read their own reports through the users/{uid}/reports rule.
    // Admins can read everything for triage.
    match /{path=**}/reports/{reportId} {
      allow read:   if isAdmin() || (isAuth() && resource.data.status == 'solved');
      allow update: if isAdmin();
      allow delete: if isProvincialAdmin();
    }

    // ─── Announcements ───────────────────────────────────────────────────────
    match /announcements/{announcementId} {
      allow read:          if isAuth();
      allow create, update: if isMunicipalAdmin();
      allow delete:        if isProvincialAdmin();
    }

    // ─── Emergency responders ────────────────────────────────────────────────
    match /responders/{responderId} {
      allow read:          if isAuth();
      allow create, update: if isMunicipalAdmin();
      allow delete:        if isProvincialAdmin();
    }

    // ─── FCM broadcast records ───────────────────────────────────────────────
    match /broadcasts/{broadcastId} {
      allow read:   if isAdmin();
      allow create: if isAdmin();
      allow delete: if isProvincialAdmin();
    }

    // ─── Audit logs (append-only for admins; only super_admin can delete) ────
    match /audit_logs/{logId} {
      allow read:   if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isSuperAdmin();
    }

    // ─── App config ──────────────────────────────────────────────────────────
    match /config/{docId} {
      allow read:  if isAdmin();
      allow write: if isProvincialAdmin();
    }

    // ─── Rate limit counters ─────────────────────────────────────────────────
    match /rate_limits/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ─── Demo / seed meta ────────────────────────────────────────────────────
    match /demo_meta/{docId} {
      allow read:  if isAdmin();
      allow write: if isProvincialAdmin();
    }
  }
}
