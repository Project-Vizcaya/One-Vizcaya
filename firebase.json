{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "one-vizcaya-app",
          "appId": "1:899155311025:android:2001ac798a04ba93dee590",
          "fileOutput": "apps/mobile/android/app/google-services.json"
        }
      },
      "dart": {
        "apps/mobile/lib/firebase_options.dart": {
          "projectId": "one-vizcaya-app",
          "configurations": {
            "android": "1:899155311025:android:2001ac798a04ba93dee590",
            "ios": "1:899155311025:ios:cb17cbe02262e24adee590",
            "web": "1:899155311025:web:39a0ba252222d089dee590"
          }
        }
      }
    }
  },
  "hosting": {
    "public": "apps/admin/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "/assets/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ]
  },
  "functions": [
    {
      "source": "apps/functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
